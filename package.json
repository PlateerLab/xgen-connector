{
  "name": "xgen-connector",
  "version": "0.1.12",
  "description": "XGEN Connector — desktop client to log in to an XGEN instance, browse your agents, and chat (SSE streaming). Works with agent_geny / agent_xgen / agent_harness agents.",
  "author": "PlateerLab",
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/PlateerLab/xgen-connector",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlateerLab/xgen-connector.git"
  },
  "scripts": {
    "test": "tsx --test test/client.test.ts test/sse.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
